{
  "name": "react-usetask-z",
  "version": "2.0.0",
  "description": "Structured concurrency and async task runtime for React",
  "license": "MIT",
  "author": "Delpi.Kye",
  "type": "module",
  "main": "./build/index.cjs",
  "module": "./build/index.mjs",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.mjs",
      "require": "./build/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf build dist",
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/delpikye-v/react-usetask-z.git"
  },
  "homepage": "https://github.com/delpikye-v/react-usetask-z#readme",
  "bugs": {
    "url": "https://github.com/delpikye-v/react-usetask-z/issues"
  },
  "keywords": [
    "react",
    "react-hooks",
    "hook",
    "async",
    "task",
    "scheduler",
    "runtime",
    "structured-concurrency",
    "coroutine",
    "abortcontroller",
    "async-runtime",
    "polling",
    "retry",
    "timeout",
    "concurrency",
    "useTask",
    "react-task",
    "task-runtime"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.38",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "rollup": "^4.12.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-typescript2": "^0.37.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}